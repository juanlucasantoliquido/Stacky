auth/auth.json
auth/ado_auth.json
Stacky Agents/backend/.env
Stacky Agents/backend/.env.local
Stacky Agents/backend/projects/*/auth/*.json
!Stacky Agents/backend/.env.example

# Credenciales y secrets del agente QA UAT (y otros agentes)
.secrets/*.env
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/

# Estado runtime — no versionar
pipeline/state.json
state/
active_project.json
# DB viva del runtime — binario, no versionar
data/
*.db
*.sqlite
*.sqlite3
NOTIFICATIONS.json

# Proyectos / tickets scrapeados — contienen datos del cliente
projects/

# Credenciales y sesiones
auth/

# Logs
*.log
logs/
test_logs/

# Artefactos de build / temporales
dist/
build/
*.zip

# Deploys locales de Stacky Agents
Stacky Agents/DeployStackyAgents/

# Agentes canónicos versionados. El manifest se regenera en runtime/release.
Stacky Agents/backend/Stacky/*
!Stacky Agents/backend/Stacky/agents/
!Stacky Agents/backend/Stacky/agents/**
!Stacky Agents/backend/Stacky/agents/*.agent.md
Stacky Agents/backend/Stacky/agents/manifest.json
# Skills: carpeta versionada (fixture de ejemplo para tests + documento de referencia)
!Stacky Agents/backend/Stacky/skills/
!Stacky Agents/backend/Stacky/skills/**

# VS Code
.vscode/

# Repo clonado localmente para referencia
engram/

# Volcado de memoria de herramienta externa (no es código del proyecto)
/memory/

# Backups de node_modules dejados por reinstalaciones (Install-Dependencies.ps1)
node_modules.stale-*/

# Entornos virtuales de Python (machine-specific, nunca versionar)
venv/
.venv/

