# Agenda Web — Cuenta QA para Playwright
# Copiar este archivo a: Tools/Stacky/.secrets/agenda_web.env
# NUNCA commitear .secrets/*.env — está cubierto por .gitignore

AGENDA_WEB_USER=<usuario QA>
AGENDA_WEB_PASS=<password de la cuenta QA>
AGENDA_WEB_BASE_URL=http://localhost/AgendaWeb/

# Opcional: operador para el audit log de ado_evidence_publisher.py
# Si no se setea, usa `git config user.email`
# STACKY_OPERATOR=tu.email@empresa.com
