ADO_ORG=
ADO_PROJECT=
ADO_PAT=
DATABASE_URL=sqlite:///./data/stacky_agents.db
# LLM_BACKEND: motor de las llamadas LLM INTERNAS de Stacky (enriquecimiento de
# contexto, criterios, KPIs, chat). NO es el runtime del agente (eso es el selector
# "Ejecutar con" del frontend).
#   copilot       -> GitHub Copilot (sirve modelos Claude/otros de tu licencia Copilot)
#   claude_cli    -> CLI `claude` con tu cuenta Claude (OAuth de disco / Pro), SIN Copilot (Plan 37)
#   vscode_bridge -> modelos via el bridge de VS Code (tambien Copilot)
#   mock          -> respuestas canned (solo dev)
# Para usar tu cuenta Claude en TODO (agente + cerebro interno): selector=Claude Code
# CLI  Y  LLM_BACKEND=claude_cli.
LLM_BACKEND=copilot
LLM_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173
PORT=5050
# Override opcional del root del repo del cliente (donde el agente escribe
# Agentes/outputs). Normalmente se infiere del workspace_root del proyecto
# activo; setealo sólo si esa inferencia no aplica en tu deploy.
# STACKY_REPO_ROOT=C:/ruta/al/repo

# Claude Code CLI runtime
# Modelo fijo para toda invocacion del CLI (vacio = router decide)
CLAUDE_CODE_CLI_MODEL=claude-sonnet-4-6
# Reasoning effort: low | medium | high (vacio = default del CLI)
CLAUDE_CODE_CLI_EFFORT=medium
# Plan 37 (F3.1) — cap de sesion en seg. Default FINITO (1800=30min) para que un
# run colgado no quede zombie sin limite. 0 = ilimitado (opt-in explicito).
# CLAUDE_CODE_CLI_TIMEOUT=1800

# ── Arnés de agentes (flags configurables vía UI — Plan 33) ──────────────────
# Todos se pueden editar desde Configuración > Arnés en la UI, o directamente
# aquí. El operador puede sobreescribir cualquier default con =false / =true.
#
# Grupo: claude_code_cli
# CLAUDE_CODE_CLI_CONTRACT_GATE_ENABLED=false   # bool, default: false
# CLAUDE_CODE_CLI_AUTOCORRECT_ENABLED=false     # bool, default: false
# CLAUDE_CODE_CLI_AUTOCORRECT_MAX_RETRIES=2     # int,  default: 2
# CLAUDE_CODE_CLI_HOOKS_ENABLED=false           # bool, default: false
# CLAUDE_CODE_CLI_PROJECT_KNOWLEDGE_ENABLED=false  # bool, default: false
# CLAUDE_CODE_CLI_PROJECT_KNOWLEDGE_PROJECTS=      # csv,  default: "" (todos)
# CLAUDE_CODE_CLI_RESUME_ENABLED=false          # bool, default: false
# CLAUDE_CODE_CLI_RESUME_PROJECTS=              # csv,  default: "" (todos)
# CLAUDE_CODE_CLI_MCP_ENABLED=false             # bool, default: false
# CLAUDE_CODE_CLI_MCP_PROJECTS=                 # csv,  default: "" (todos)
#
# Grupo: codex_cli
# CODEX_CLI_CONTRACT_GATE_ENABLED=false         # bool, default: false
# CODEX_CLI_AUTOCORRECT_ENABLED=false           # bool, default: false
# CODEX_CLI_AUTOCORRECT_MAX_RETRIES=2           # int,  default: 2
# CODEX_CLI_MODEL_DENYLIST=                     # csv,  default: "" (sin denylist)
# CODEX_CLI_RESUME_ENABLED=false                # bool, default: false
# CODEX_CLI_RESUME_PROJECTS=                    # csv,  default: "" (todos)
#
# Grupo: global — contexto y memoria
# STACKY_CONTEXT_BUDGET_ENABLED=false           # bool, default: false
# STACKY_CONTEXT_BUDGET_PROJECTS=               # csv,  default: "" (todos)
# STACKY_CONTEXT_BUDGET_TOKENS=25000            # int,  default: 25000
# STACKY_CONTEXT_DEDUP_ENABLED=false            # bool, default: false
# STACKY_CONTEXT_DEDUP_PROJECTS=                # csv,  default: "" (todos)
# STACKY_MEMORY_INJECTION_ENABLED=false         # bool, default: false (env_only)
# STACKY_MEMORY_INJECTION_PROJECTS=             # csv,  default: "" (todos)
# STACKY_MEMORY_CAPS_JSON=                      # json, default: "" (defaults hardcodeados)
# STACKY_MEMORY_REVIEW_SWEEP_HOURS=0            # int,  default: 0 (off)
# STACKY_MEMORY_DIRECTIVE_MAX_CHARS=4000        # int,  default: 4000
# STACKY_MEMORY_INJECT_SCOPES=                  # csv,  default: "" (project,team,global)
#
# Grupo: global — skills y egress
# STACKY_SKILLS_ENABLED=false                   # bool, default: false
# STACKY_SKILLS_PROJECTS=                       # csv,  default: "" (todos)
# STACKY_CLI_EGRESS_ENABLED=false               # bool, default: false (env_only)
#
# Grupo: global — runaway guard
# STACKY_RUNAWAY_MAX_TURNS=0                    # int,  default: 0 (sin límite)
# STACKY_RUNAWAY_MAX_COST_USD=0.0               # float, default: 0.0 (sin límite)
#
# Grupo: global — visibilidad y telemetría
# STACKY_ADO_RUN_FOOTER_ENABLED=false           # bool, default: false
# STACKY_WEBHOOKS_V2_ENABLED=false              # bool, default: false
# STACKY_DESKTOP_NOTIFY_ENABLED=false           # bool, default: false
# STACKY_LIVE_TELEMETRY_ENABLED=false           # bool, default: false
# STACKY_SELF_REVIEW_MODE=off                   # csv,  default: "off" (off|annotate|gate)
# STACKY_SELF_REVIEW_MIN_SCORE=0.7              # float, default: 0.7
# STACKY_ADO_FAILURE_COMMENT_ENABLED=false      # bool, default: false
# STACKY_DIGEST_INTERVAL_HOURS=0                # int,  default: 0 (off)
# STACKY_PIPELINES_ENABLED=false                # bool, default: false
# STACKY_MAX_CONCURRENT_RUNS=0                  # int,  default: 0 (ilimitado)
#
# Grupo: global — smart dispatch y budget
# STACKY_ARTIFACT_INTAKE_ENABLED=false          # bool, default: false (env_only)
# STACKY_RUN_ADVISOR_ENABLED=false              # bool, default: false (env_only)
# STACKY_RUN_ADVISOR_ENFORCE=false              # bool, default: false (env_only)
# STACKY_BUDGET_PER_TICKET_USD=0.0              # float, default: 0.0 (sin límite, env_only)
# STACKY_EVALS_INTERVAL_HOURS=0                 # int,  default: 0 (off, env_only)
# STACKY_EVAL_GATE_MODE=warn                    # csv,  default: "warn" (env_only)
# STACKY_RUN_CACHE_DAYS=0                       # int,  default: 0 (off, env_only)
#
# Grupo: global — motor invisible (complejidad, reparación, caché, retrieval)
# STACKY_COMPLEXITY_ESTIMATION_ENABLED=false    # bool, default: false
# STACKY_RUN_REPAIR_ENABLED=false               # bool, default: false
# STACKY_DIFFICULTY_ROUTING_ENABLED=false       # bool, default: false
# STACKY_ADO_READ_CACHE_TTL_SEC=0               # int,  default: 0 (sin caché)
# STACKY_RETRIEVAL_EXPANSION_ENABLED=false      # bool, default: false
# STACKY_CONTEXT_RERANK_ENABLED=false           # bool, default: false
# STACKY_PARALLEL_INJECTORS_ENABLED=false       # bool, default: false
# STACKY_ADO_PREWARM_ENABLED=false              # bool, default: false
# STACKY_CAPS_ADVISOR_ENABLED=false             # bool, default: false
#
# Grupo: global — lifecycle e higiene (Plan 28, default true desde Plan 33)
# STACKY_RUNNER_REAP_ON_CLOSE_ENABLED=true      # bool, default: true
# STACKY_LOG_FLUSH_INCREMENTAL_ENABLED=false    # bool, default: false
# STACKY_ORPHAN_REAPER_ENABLED=true             # bool, default: true
# STACKY_ORPHAN_REAPER_INTERVAL_SEC=0           # int,  default: 0 (solo al arrancar)
# STACKY_STALL_WATCHDOG_SECONDS=0               # int,  default: 0 (off)
# STACKY_PENDING_TASK_STRICT_VALIDATION_ENABLED=true  # bool, default: true
# STACKY_PUBLISH_IDEMPOTENT_GUARD_ENABLED=false # bool, default: false
# STACKY_RELIABILITY_KPIS_ENABLED=false         # bool, default: false
#
# Grupo: global — calidad del resultado (Plan 29)
# STACKY_ACCEPTANCE_CRITERIA_INJECTION_ENABLED=false  # bool, default: false
# STACKY_ACCEPTANCE_CRITERIA_PROJECTS=                # csv,  default: "" (todos)
# STACKY_ADAPTIVE_EFFORT_ENABLED=false          # bool, default: false
# STACKY_EFFORT_FLOOR=medium                    # csv,  default: "medium"
# STACKY_CRITERIA_REPAIR_ENABLED=false          # bool, default: false
# STACKY_CRITERIA_REPAIR_MAX_RETRIES=1          # int,  default: 1
# STACKY_CLI_FEWSHOT_ENABLED=false              # bool, default: false
# STACKY_CLI_FEWSHOT_K=2                        # int,  default: 2
# STACKY_CLI_FEWSHOT_PROJECTS=                  # csv,  default: "" (todos)
# STACKY_QUALITY_KPIS_ENABLED=false             # bool, default: false
#
# Grupo: global — integridad verificada (Plan 30, default true desde Plan 33)
# STACKY_RUN_PREFLIGHT_GATE_ENABLED=true        # bool, default: true
# STACKY_VERIFY_TASK_BEFORE_CONSUMED_ENABLED=true  # bool, default: true
# STACKY_OUTPUT_GROUNDING_ENABLED=false         # bool, default: false
# STACKY_OUTPUT_GROUNDING_REPAIR=false          # bool, default: false
# STACKY_INTEGRITY_KPIS_ENABLED=false           # bool, default: false
# STACKY_TRANSIENT_RUN_RETRY_ENABLED=false      # bool, default: false (DIFERIDO)
# STACKY_TRANSIENT_RUN_RETRY_MAX=1              # int,  default: 1 (DIFERIDO)

# ── Plan 36 — Selector de runtime sin fallback silencioso ─────────────────
# Si true (default), /run loguea y marca cuando el runtime vino ausente
# y tuvo que aplicarse el default github_copilot. Nunca cambia de runtime en
# silencio; solo registra el evento para diagnóstico del operador.
# STACKY_RUNTIME_STRICT=true                    # bool, default: true

# ── Plan 38 — Versión visible, épica desde brief, trazabilidad ───────────
# B0 — Habilita POST /api/tickets/epics/from-brief (human-in-the-loop).
# STACKY_EPIC_FROM_BRIEF_ENABLED=true           # bool, default: true
# Plan 41 — Autopublica la épica brief→épica desde el backend al cerrar la run
# (idempotente, fallo ruidoso). Palanca de emergencia para apagarla.
# STACKY_EPIC_AUTOPUBLISH_BACKEND=true          # bool, default: true
# Fix robusto brief→épica — pase correctivo: si el BusinessAgent (one-shot) devuelve
# narración en vez del HTML de la épica, se le pide UNA vez por stdin que re-emita SOLO
# el HTML antes de cerrar la sesión. OFF → solo fallo ruidoso (needs_review), sin retry.
# STACKY_EPIC_REPAIR_ENABLED=true               # bool, default: true
# C0/C1 — Persiste trazabilidad (agent_type, prompt_sha, produced_files) en metadata.
# STACKY_EXECUTION_TRACE_ENABLED=true           # bool, default: true
# C0/C1 — Incluye prompt_text completo en metadata (privacidad: default OFF).
# STACKY_TRACE_PROMPT_TEXT_ENABLED=false        # bool, default: false

# ── Plan 39 — Historial de runs, fix épica CLI y BD read-only ────────────
# C2 — Inyecta directiva de acceso a BD read-only en el perfil del cliente.
#      Seguro: NUNCA incluye el password (solo usuario, servidor, motor).
# STACKY_DB_READONLY_DIRECTIVE_ENABLED=false    # bool, default: false (group: database)
#
# A1 — Habilita GET /api/executions/history con historial completo de runs.
# STACKY_EXECUTION_HISTORY_ENABLED=false        # bool, default: false (group: observability)
