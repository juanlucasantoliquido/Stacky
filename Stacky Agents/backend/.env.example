ADO_ORG=
ADO_PROJECT=
ADO_PAT=
DATABASE_URL=sqlite:///./data/stacky_agents.db
LLM_BACKEND=copilot
LLM_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173
PORT=5050
# Override opcional del root del repo del cliente (donde el agente escribe
# Agentes/outputs). Normalmente se infiere del workspace_root del proyecto
# activo; setealo sólo si esa inferencia no aplica en tu deploy.
# STACKY_REPO_ROOT=C:/ruta/al/repo
