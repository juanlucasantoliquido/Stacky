# harness_defaults.env — Snapshot del arnés que se hornea como default del deploy.
# GENERADO por deployment/export_harness_defaults.py desde el deploy vivo.
# Solo contiene flags del arnés (FLAG_REGISTRY); NUNCA credenciales ni secretos.
# Para refrescarlo con tu config actual: volvé a generar el deploy
# (PrepararPublicacion*.bat) — el build lo regenera y lo hornea solo.

STACKY_ACCEPTANCE_CONTRACT_ENABLED=true
STACKY_ACCEPTANCE_CRITERIA_INJECTION_ENABLED=true
STACKY_ACCEPTANCE_GATE_ENABLED=true
STACKY_ACCEPTANCE_INTEGRITY_ENABLED=true
STACKY_ACCEPTANCE_KPIS_ENABLED=true
STACKY_ACCEPTANCE_REPAIR_ENABLED=true
STACKY_ACCEPTANCE_VERDICT_CARD_ENABLED=true
STACKY_COMPLEXITY_ESTIMATION_ENABLED=true
STACKY_CONTEXT_BUDGET_PROJECTS=
STACKY_CONTEXT_BUDGET_TOKENS=25000
STACKY_CONTEXT_DEDUP_ENABLED=true
STACKY_CONTEXT_RERANK_ENABLED=true
STACKY_DESKTOP_NOTIFY_ENABLED=true
STACKY_EXEC_VERIFICATION_KPIS_ENABLED=true
STACKY_EXEC_VERIFICATION_VERDICT_CARD_ENABLED=true
STACKY_FAKE_GREEN_GUARD_ENABLED=true
STACKY_FAKE_GREEN_GUARD_HARD=true
STACKY_INTEGRITY_KPIS_ENABLED=true
STACKY_LIVE_TELEMETRY_ENABLED=true
STACKY_MEMORY_INJECTION_ENABLED=false
STACKY_PUBLISH_IDEMPOTENT_GUARD_ENABLED=true
STACKY_QUALITY_KPIS_ENABLED=true
STACKY_RELIABILITY_KPIS_ENABLED=true
STACKY_SELF_REVIEW_MODE=off
STACKY_VERIFY_TASK_BEFORE_CONSUMED_ENABLED=true
