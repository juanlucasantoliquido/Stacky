{
  "_eval_id": "auth_session_blocked_credentials_invalid",
  "_description": "Credenciales incorrectas — el login programático falla y debe retornar AUTH_CREDENTIALS_INVALID.",
  "_layer": "unit",
  "_scenario": "El login navegó a FrmLogin.aspx pero no redirigió a FrmAgenda/FrmMain (password incorrecto).",
  "input": {
    "mode": "normal",
    "mock_auth_file_exists": false,
    "mock_credentials": {
      "AGENDA_WEB_USER": "usuario_invalido",
      "AGENDA_WEB_PASS": "clave_incorrecta",
      "AGENDA_WEB_BASE_URL": "http://localhost:35017/AgendaWeb/"
    },
    "mock_login_result": {
      "ok": false,
      "reason": "AUTH_CREDENTIALS_INVALID",
      "error": "Login falló — sigue en http://localhost:35017/AgendaWeb/FrmLogin.aspx. Verificar AGENDA_WEB_USER / AGENDA_WEB_PASS."
    }
  },
  "expected_output": {
    "ok": false,
    "verdict": "BLOCKED",
    "reason": "AUTH_CREDENTIALS_INVALID",
    "category": "ENV",
    "dry_run": false,
    "reused": false,
    "human_action_required_contains": "AGENDA_WEB_USER"
  },
  "assertions": [
    "result.ok == False",
    "result.verdict == 'BLOCKED'",
    "result.reason == 'AUTH_CREDENTIALS_INVALID'",
    "result.category == 'ENV'",
    "result.human_action_required is not None",
    "result.storage_state_path is None"
  ]
}
