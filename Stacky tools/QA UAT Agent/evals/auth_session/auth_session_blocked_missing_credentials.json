{
  "_eval_id": "auth_session_blocked_missing_credentials",
  "_description": "Credenciales ausentes — debe bloquear con MISSING_CREDENTIALS antes de intentar login.",
  "_layer": "unit",
  "_scenario": "Las variables AGENDA_WEB_USER y AGENDA_WEB_PASS no están seteadas en el entorno.",
  "input": {
    "mode": "normal",
    "mock_credentials": {
      "AGENDA_WEB_USER": "",
      "AGENDA_WEB_PASS": "",
      "AGENDA_WEB_BASE_URL": "http://localhost:35017/AgendaWeb/"
    }
  },
  "expected_output": {
    "ok": false,
    "verdict": "BLOCKED",
    "reason": "MISSING_CREDENTIALS",
    "category": "ENV",
    "dry_run": false,
    "reused": false,
    "human_action_required_contains": "AGENDA_WEB_USER"
  },
  "assertions": [
    "result.ok == False",
    "result.verdict == 'BLOCKED'",
    "result.reason == 'MISSING_CREDENTIALS'",
    "result.category == 'ENV'",
    "result.human_action_required is not None",
    "'AGENDA_WEB_USER' in result.human_action_required"
  ]
}
