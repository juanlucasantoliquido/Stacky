      "finished_at": "__NOW_MINUS_180S__",
      "deployment_fingerprint": "build-old-abc123",
      "tool_version": "1.1.0"
    },
    "mock_cooldown_ttl_s": 600
  },
  "expected_output": {
    "ok": true,
    "verdict": "OK",
    "reason": "FINGERPRINT_CHANGED",
    "cooldown_active": false,
    "forced": false,
    "previous_run_id": "uat-122-20260513T090000Z-ghi789"
  },
  "assertions": [
    "result.ok == True",
    "result.verdict == 'OK'",
    "result.reason == 'FINGERPRINT_CHANGED'",
    "result.cooldown_active == False"
  ]
