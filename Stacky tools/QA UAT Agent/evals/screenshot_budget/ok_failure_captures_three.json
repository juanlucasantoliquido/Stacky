{
  "_eval_id": "ok_failure_captures_three",
  "_description": "Un step fallido puede capturar hasta 3 screenshots (capture_index 0,1,2). El cuarto intento debe ser rechazado.",
  "_layer": "unit",
  "input": {
    "budget": {
      "on_success_per_step": 1,
      "on_failure_per_step": 3,
      "max_total_per_scenario": 25,
      "disabled": false
    },
    "steps": [
      {"step_ok": false, "capture_index": 0},
      {"step_ok": false, "capture_index": 1},
      {"step_ok": false, "capture_index": 2},
      {"step_ok": false, "capture_index": 3}
    ]
  },
  "expected_output": {
    "captured": 3,
    "skipped": 1,
    "exceeded": false
  },
  "assertions": [
    "captured == 3",
    "skipped == 1",
    "exceeded == False"
  ]
}
