        {"alias_semantic": "tabRelaciones", "selector": "#c_tabRelaciones", "is_decorative": false, "is_interactive": true, "role": "tab"}
      ],
      "grids": [
        {"alias_semantic": "gridObligaciones", "selector": "#c_GridObligaciones"}
      ]
