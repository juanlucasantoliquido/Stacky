  "PopUpCompromisos": {
    "modal_id": "#c_dlgCompromisos",
    "deteccion_apertura": "el.classList.contains('open') && el.innerHTML.length > 100",
    "selectors": {
      "grid_obligaciones": "#c_GridObligacionesCompromisos",
