      "ddl_figura": "#c_ddlFiguraCompromiso",
      "ddl_accion": "#c_ddlTarCompromiso",
      "btn_guardar": "#c_btnGuardarModalCompromisos",
      "btn_cancelar": "#c_btnCancelarModalCompromisos"
    },
    "ddl_figura_opciones": {
      "A01": "Avalista Principal",
      "NP": "No Procede",
      "T01": "Titular Principal",
      "XX": "Todas las Figuras",
      "AX": "Todos los Avalistas",
      "TX": "Todos los Titulares"
    },
    "ddl_accion_opciones_comunes": {
      "COPA": "Compromiso de Pago Parcial",
      "CPPA": "Compromiso de Pago Parcial",
      "RACP": "Compromiso de Pago Parcial (Tel. Entrante)",
      "TACP": "Compromiso de Pago Parcial (Tel. Saliente)",
      "VACP": "Compromiso de Pago Parcial (visita)",
      "COTO": "Compromiso de Pago Total",
      "CPPT": "Compromiso de Pago Total",
      "RACT": "Compromiso de Pago Total (Tel. Entrante)",
      "TACT": "Compromiso de Pago Total (Tel. Saliente)",
      "VACT": "Compromiso de Pago Total (visita)",
      "COEL": "Compromiso Eliminado"
    },
    "flujo_guardar_compromiso": [
      "// 1. Abrir modal: locator('#c_btnCompromisos').click()",
      "// 2. Esperar apertura: waitForFunction(() => el.classList.contains('open') && el.innerHTML.length > 100)",
      "// 3. Llenar monto en #c_abfProyeccion (si cuotas morosas vacías, ingresar manualmente)",
      "//    CRITICO: ValidarCompromiso() falla si abfProyeccion == 0",
      "// 4. Click #c_btnAgregarPromesa — esperar 3-4s para PostBack UpdatePanel",
      "//    Resultado: fila aparece en GridPromesasPago con operacion, fecha, cantidad",
      "// 5. Setear Figura via JS: el.value='T01'; el.dispatchEvent(new Event('change', {bubbles:true}))",
      "// 6. Setear Accion via JS: el.value='CPPA'; el.dispatchEvent(new Event('change', {bubbles:true}))",
      "//    CRITICO: Select2 oculta los <select> — NO usar selectOption(), usar JS directo",
      "// 7. GUARDAR se habilita automaticamente (clase 'aspNetDisabled' se remueve)",
      "// 8. Click GUARDAR: locator('#c_btnGuardarModalCompromisos').click({ force: true, noWaitAfter: true })",
      "//    force:true necesario — c_panelBtnCompromisos (overlay) bloquea el click normal",
      "// 9. Esperar 4s. Modal queda ABIERTO por diseno (no hay dlgCompromisos.IsModalVisible=false)",
      "// 10. Verificar: toast 'Los compromisos de pagos se ha guardado correctamente' en body"
    ],
    "advertencias": [
      "c_panelBtnCompromisos es un overlay — siempre usar force:true en GUARDAR",
      "Select2 oculta los <select> de Figura y Accion — no usar selectOption()",
      "GUARDAR empieza como aspNetDisabled — se habilita despues de AgregarPromesa exitoso",
      "Cuotas Morosas puede estar VACIA en dev — llenar c_abfProyeccion manualmente con monto",
      "Modal NO se cierra despues de guardar — indicador de exito es el toast o agenda vaciada"
    ],
