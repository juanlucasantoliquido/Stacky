  "FrmBusqueda.aspx": {
    "selectors": {
      "campo_cod_cliente": "#c_abfCodCliente",
      "btn_buscar": "#c_btnOk",
      "grid_personas": "#c_GridPersonas",
      "grid_obligaciones": "#c_GridObligaciones"
    },
    "flujo": [
      "goto(BASE_URL + 'FrmBusqueda.aspx', { waitUntil: 'load' })",
      "fill('#c_abfCodCliente', CLCOD)",
      "locator('#c_btnOk').click({ noWaitAfter: true })",
      "waitForFunction: GridPersonas tiene filas",
      "click primera fila GridPersonas (PostBack UpdatePanel → muestra GridObligaciones)",
      "waitForFunction: GridObligaciones tiene filas",
      "click primera fila GridObligaciones → Redireccionar('FrmDetalleClie.aspx')"
    ],
    "datos_prueba": {
      "PABLO_AGPERFIL": "1",
      "CLCOD_candidato": "4127924112345393",
      "cliente_nombre": "MONTEZUMA GARRIDO NATALIA",
      "OGCOD_ejemplo": "MOR0026973",
      "fuente": "SELECT ob.OCRAIZ, og.OGCOD FROM ROBLG og JOIN ROBCL ob ON ob.OCOBLIG=og.OGCOD WHERE og.OGLOTE='4127924112345393'"
    },
    "notas": [
      "OCRAIZ = CLCOD — usar como valor en #c_abfCodCliente para busqueda exacta",
      "GridPersonas SelectedIndexChanged → UpdatePanel GridObligaciones (mismo PostBack)",
      "GridObligaciones SelectedIndexChanged → Session[lote] + Redireccionar FrmDetalleClie",
      "Es la forma mas segura de entrar a FrmDetalleClie — no depende de agenda diaria",
      "PABLO tiene 2 obligaciones: MOR0024967 (OGLIDER=1, primera en grid) y MOR0026973 (OGLIDER=0, segunda)",
      "MOR0024967 puede tener compromiso activo del dia — usar MOR0026973 (segunda fila en GridObligacionesCompromisos)"
    ]
  },
  "FrmLogin.aspx": {
    "selectors": {
      "usuario": "#c_abfUsuario",
      "password": "#c_abfContrasena",
      "btn_ok": "#c_btnOk"
    },
    "flow": [
      "goto(BASE_URL + 'FrmLogin.aspx', { waitUntil: 'load' })",
      "fill('#c_abfUsuario', USER)",
      "fill('#c_abfContrasena', PASS)",
      "locator('#c_btnOk').click({ noWaitAfter: true })",
      "waitForURL(/FrmAgenda/, { timeout: 25000 })"
    ],
    "notas": "noWaitAfter:true es critico — el PostBack de ASP.NET navega en el mismo request"
  },
  "FrmAgenda.aspx": {
    "selectors": {
      "grid_agenda_usuario": "#c_GridAgendaUsu",
      "grid_agenda_auto": "#c_GridAgendaAut",
      "btn_buscar": "#c_btnOk",
      "filtro_nombre_cliente": "#c_abfNombreCliente",
      "filtro_ruc": "#c_abfRUC",
      "filtro_corredor": "#c_abfCorredor",
      "filtro_empresa": "#c_ddlEmpresa",
      "collapse_busqueda": "#c_acsBusquedaAgenda"
    },
    "flow_entrada_normal": [
      "goto(BASE_URL + 'FrmAgenda.aspx', { waitUntil: 'load' })",
      "locator('#c_GridAgendaUsu').waitFor({ state: 'visible', timeout: 15000 })",
      "locator('#c_GridAgendaUsu tbody tr').first().locator('td').first().click()"
    ],
    "flow_fallback_busqueda": [
      "// Si la agenda está vacía (0 filas), usar búsqueda avanzada:",
      "locator('.collapsible-header:has-text(\"Búsqueda Avanzada\"), #c_acsBusquedaAgenda').click()",
      "waitForTimeout(500)",
      "locator('#c_abfNombreCliente').fill(NOMBRE_CLIENTE)",
      "locator('#c_btnOk').click({ noWaitAfter: true })",
      "waitForFunction(() => !!document.querySelector('#c_GridAgendaUsu tbody tr'), { timeout: 15000 })",
      "locator('#c_GridAgendaUsu tbody tr').first().locator('td').first().click()"
    ],
    "notas": "La agenda puede estar vacía para PABLO si el cliente fue procesado. Siempre intentar búsqueda por nombre como fallback.",
    "fallback_busqueda_requerido": true
  },
