{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "NavigationPlan/1.0",
  "title": "NavigationPlan",
  "description": "Resolved navigation plan for a UAT scenario. Input for playwright_test_generator.py and the runtime executeNavigationPlan() helper. Sprint N5-02.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "plan_version",
    "ticket_id",
    "scenario_id",
    "target_screen",
    "lane",
    "strategy",
    "steps",
    "arrival_assertions"
  ],
  "properties": {
    "plan_version": { "type": "string", "const": "1.0" },
    "ticket_id": { "type": ["integer", "string"] },
    "scenario_id": { "type": "string", "minLength": 1 },
    "target_screen": { "type": "string", "minLength": 1 },
    "lane": { "type": "string", "minLength": 1 },
    "strategy": {
      "type": "string",
      "enum": ["direct_entry", "deeplink", "human_path", "playbook"]
    },
    "path_id": { "type": ["string", "null"] },
    "playbook_id": { "type": ["string", "null"] },
    "entrypoint": { "type": ["string", "null"] },
    "deeplink_url": { "type": ["string", "null"] },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/NavigationStep" }
    },
    "arrival_assertions": {
      "type": "array",
      "minItems": 1,
      "description": "Mandatory assertions after the last navigation step.",
      "items": { "$ref": "#/$defs/AssertionSpec" }
    },
    "session_requirements": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "require_valid_storagestate": { "type": "boolean", "default": true },
        "storagestate_max_age_minutes": { "type": "integer", "minimum": 1, "default": 120 }
      }
    },
    "resolved_at": { "type": "string" },
    "resolver_version": { "type": "string" }
  },
  "$defs": {
    "NavigationStep": {
      "type": "object",
      "additionalProperties": true,
      "required": ["step_index", "method", "description"],
      "properties": {
        "step_index": { "type": "integer", "minimum": 1 },
        "method": {
          "type": "string",
          "enum": [
            "goto_direct",
            "goto_deeplink",
            "form_submit",
            "dopostback",
            "link_click",
            "menu_click",
            "row_click",
            "tab_click",
            "button_click",
            "fill",
            "select",
            "check",
            "wait"
          ]
        },
        "description": { "type": "string" },
        "target_url": { "type": ["string", "null"] },
        "eventtarget": { "type": ["string", "null"] },
        "eventargument": { "type": ["string", "null"] },
        "selector": { "type": ["string", "null"] },
        "wait_url_contains": { "type": ["string", "null"] },
        "timeout_ms": { "type": "integer", "minimum": 1, "default": 45000 },
        "retries": { "type": "integer", "minimum": 0, "default": 3 },
        "data_bindings": {
          "type": "object",
          "description": "Mapping of form fields to keys in available_data.",
          "additionalProperties": { "type": "string" }
        },
        "intermediate_assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/AssertionSpec" }
        },
        "screenshot_label": { "type": "string" }
      }
    },
    "AssertionSpec": {
      "type": "object",
      "additionalProperties": true,
      "required": ["assertion_id", "type", "description"],
      "properties": {
        "assertion_id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "url_contains",
            "url_not_contains",
            "dom_visible",
            "dom_not_visible",
            "dom_text_contains",
            "page_title_contains",
            "page_title_not_contains",
            "no_aspnet_error",
            "no_login_redirect",
            "no_500_response"
          ]
        },
        "description": { "type": "string" },
        "selector": { "type": ["string", "null"] },
        "expected_value": { "type": ["string", "null"] },
        "timeout_ms": { "type": "integer", "minimum": 1, "default": 10000 },
        "severity": {
          "type": "string",
          "enum": ["hard", "soft"],
          "default": "hard"
        },
        "category_on_fail": {
          "type": "string",
          "enum": ["NAV", "ENV", "DATA", "APP"],
          "default": "NAV"
        }
      }
    }
  }
}
