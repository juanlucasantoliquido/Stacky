{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "NavigationStepResults/1.0",
  "title": "NavigationStepResults",
  "description": "Per-run record of every NavigationPlan step execution. Written by navigation_executor.ts at the end of beforeEach (Sprint N5-06). Consumed by the runner / failure analyzer.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "ticket_id", "scenario_id", "strategy", "navigation_ok", "steps", "elapsed_ms_total"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "ticket_id": { "type": ["integer", "string"] },
    "scenario_id": { "type": "string", "minLength": 1 },
    "strategy": {
      "type": "string",
      "enum": ["direct_entry", "deeplink", "human_path", "playbook"]
    },
    "navigation_ok": { "type": "boolean" },
    "elapsed_ms_total": { "type": "integer", "minimum": 0 },
    "target_screen": { "type": "string" },
    "final_url": { "type": "string" },
    "failed_step": { "type": ["integer", "null"] },
    "error_code": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "is_terminal": { "type": ["boolean", "null"] },
    "category": {
      "type": ["string", "null"],
      "enum": ["NAV", "ENV", "DATA", "APP", null]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/StepResult" }
    }
  },
  "$defs": {
    "StepResult": {
      "type": "object",
      "additionalProperties": true,
      "required": ["step_index", "method", "description", "ok", "attempts", "elapsed_ms"],
      "properties": {
        "step_index": { "type": "integer", "minimum": 1 },
        "method": { "type": "string" },
        "description": { "type": "string" },
        "ok": { "type": "boolean" },
        "attempts": { "type": "integer", "minimum": 1 },
        "elapsed_ms": { "type": "integer", "minimum": 0 },
        "url_before": { "type": "string" },
        "url_after": { "type": "string" },
        "intermediate_assertions_passed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "intermediate_assertions_failed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "screenshots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "error_code": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] },
        "is_terminal": { "type": ["boolean", "null"] },
        "category": {
          "type": ["string", "null"],
          "enum": ["NAV", "ENV", "DATA", "APP", null]
        },
        "detail": { "type": ["string", "null"] }
      }
    }
  }
}
