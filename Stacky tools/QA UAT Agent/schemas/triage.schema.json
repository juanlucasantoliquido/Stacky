{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "triage/1.0",
  "title": "FailureTriage",
  "description": "Schema for triage.json artifacts produced by failure_triage.py (Sprint 6)",
  "type": "object",
  "required": [
    "verdict",
    "category",
    "reason",
    "confidence",
    "evidence",
    "owner",
    "next_action",
    "human_approval_required"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "description": "Schema identifier",
      "const": "triage/1.0"
    },
    "triage_version": {
      "type": "string",
      "description": "Version of the triage engine"
    },
    "ticket_id": {
      "type": ["integer", "string"],
      "description": "ADO ticket identifier or run_id in freeform mode"
    },
    "run_id": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "timestamp": {
      "type": "string",
      "description": "UTC ISO 8601 timestamp of triage execution"
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED", "MIXED", "SKIPPED"],
      "description": "Final triage verdict"
    },
    "category": {
      "type": ["string", "null"],
      "enum": ["APP", "ENV", "DATA", "PIP", "GEN", "NAV", "OBS", "SEC", "OPS", null],
      "description": "Root cause category (null only for PASS verdicts)"
    },
    "reason": {
      "type": ["string", "null"],
      "description": "Machine-readable reason code"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Triage confidence score [0.0 - 1.0]"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Evidence chain justifying the verdict"
    },
    "owner": {
      "type": "string",
      "enum": ["developer", "qa_automation", "devops", "product", "data_owner"],
      "description": "Accountable owner for next action"
    },
    "next_action": {
      "type": "string",
      "minLength": 10,
      "description": "Concrete, executable next step for the owner"
    },
    "rerun_recommended": {
      "type": "boolean",
      "description": "Whether a rerun is recommended without changes"
    },
    "publish_recommended": {
      "type": "boolean",
      "description": "Whether publishing to ADO/tracker is recommended"
    },
    "human_approval_required": {
      "type": "boolean",
      "description": "Whether a human must approve before any automated action"
    },
    "artifact_path": {
      "type": ["string", "null"],
      "description": "Absolute path to triage.json written to evidence dir"
    }
  },
  "additionalProperties": true
}
