import { test, expect } from '@playwright/test';
import * as fs from 'fs';
import * as path from 'path';

const BASE_URL = process.env.AGENDA_WEB_BASE_URL!;
const USER = process.env.AGENDA_WEB_USER!;
const PASS = process.env.AGENDA_WEB_PASS!;

if (!BASE_URL) throw new Error('AGENDA_WEB_BASE_URL env var is required');
if (!USER) throw new Error('AGENDA_WEB_USER env var is required');
if (!PASS) throw new Error('AGENDA_WEB_PASS env var is required');

// ORACLE_PROBES — generated from scenario.oraculos × ui_map.
// Consumed by the test.afterEach hook to write
// evidence/<ticket>/<sid>/assertions_<sid>.json with the actual values
// captured from the live DOM, regardless of whether the test passed,
// failed, or threw. uat_assertion_evaluator.py reads this file as the
// primary source of truth for expected/actual reconciliation; without
// it every oracle would default to status=review.
type OracleProbe = {
  oracle_id: number;
  target: string;
  tipo: string;
  expected: string | number | null;
  selector: string | null;  // CSS-ish; null for whole-page oracles
};
const ORACLE_PROBES: OracleProbe[] = [
{% for oracle in oraculos %}
  {
    oracle_id: {{ loop.index0 }},
    target: {{ oracle.target | tojson }},
    tipo: {{ oracle.tipo | tojson }},
    expected: {{ (oracle.valor if oracle.valor is not none else None) | tojson }},
    selector: {% if oracle.tipo in ('page_contains_text', 'page_not_contains_text') %}null{% else %}{{ ui_map[oracle.target] | tojson }}{% endif %}
  },
{% endfor %}
];
const ASSERTIONS_OUT_PATH = 'evidence/{{ ticket_id }}/{{ scenario_id }}/assertions_{{ scenario_id }}.json';

test.describe('ADO-{{ ticket_id }} | {{ scenario_id }} — {{ titulo }}', () => {

  test.beforeEach(async ({ page }) => {
    // SETUP: login via FrmLogin.aspx (AIS rendered controls)
    // Use noWaitAfter + waitForURL to avoid actionTimeout race on ASP.NET PostBack navigation
    await page.goto(`${BASE_URL}FrmLogin.aspx`, { waitUntil: 'load' });
    await page.fill('#c_abfUsuario', USER);
    await page.fill('#c_abfContrasena', PASS);
    await page.locator('#c_btnOk').click({ noWaitAfter: true });
    await page.waitForURL(/FrmAgenda/, { timeout: 25000 });
    await page.waitForLoadState('load', { timeout: 20000 });
  });

  test('{{ scenario_id | lower | replace(" ", "_") }} {{ titulo | lower | replace(" ", "_") | truncate(60, True, "") }}', async ({ page }) => {
    // DATA: {{ datos_requeridos | map(attribute='filtro') | join(', ') if datos_requeridos else 'N/A' }}

    // PRECONDITIONS (informational — verified by uat_precondition_checker.py before this test)
    {% for pre in precondiciones %}
    // - {{ pre }}
    {% endfor %}

    // SETUP
    await page.goto(`${BASE_URL}{{ pantalla }}`, { waitUntil: 'load' });
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_00_setup.png' });

    // Expand "Búsqueda Avanzada" panel only when needed.
    // Some Agenda layouts don't expose data-toggle attrs, so use resilient fallback.
    const advancedPanel = page.locator('#c_pnlBusqueda');
    const firstFilter = page.locator('#c_ddlDebitoAuto, #c_abfCorredor, #c_abfNombreCliente, #c_abfRUC, #c_btnOk');
    let filtersReady = await firstFilter.first().isVisible().catch(() => false);
    if (!filtersReady) {
      const toggleByHeader = page.locator('.collapsible-header:has-text("Búsqueda Avanzada"), li:has-text("Búsqueda Avanzada") .collapsible-header').first();
      const toggleByData = page.locator('[data-toggle="collapse"][href="#c_pnlBusqueda"], [data-toggle="collapse"][data-target="#c_pnlBusqueda"]').first();
      const toggleByText = page.getByText('Búsqueda Avanzada', { exact: false }).first();

      if (await toggleByHeader.count()) {
        await toggleByHeader.scrollIntoViewIfNeeded();
        await toggleByHeader.click({ timeout: 5000, force: true });
      } else if (await toggleByData.count()) {
        await toggleByData.click({ timeout: 5000, force: true });
      } else if (await toggleByText.count()) {
        await toggleByText.click({ timeout: 5000, force: true });
      }

      if (await advancedPanel.count()) {
        await advancedPanel.waitFor({ state: 'visible', timeout: 5000 }).catch(() => {});
      }
      filtersReady = await firstFilter.first().isVisible().catch(() => false);

      // Last-resort fallback for legacy WebForms layouts where the toggle
      // exists but does not update aria/visibility attributes consistently.
      if (!filtersReady && await advancedPanel.count()) {
        await page.evaluate(() => {
          const pnl = document.querySelector('#c_pnlBusqueda') as HTMLElement | null;
          if (pnl) {
            pnl.style.display = 'block';
            pnl.classList.add('active');
          }
        });
        filtersReady = await firstFilter.first().isVisible().catch(() => false);
      }
    }
    console.log('Advanced filters ready:', filtersReady);
    await page.screenshot({ path: 'screenshots/{{ scenario_id }}_panel_expanded.png' });

    // ACTION
    {% for step in pasos %}
    {% if step.accion == 'navigate' %}
    // [STEP {{ "%02d" | format(loop.index) }}] navigate to {{ step.target }}
    console.log('[STEP {{ '%02d' | format(loop.index) }}] navigate {{ step.target }}');
    await page.goto(`${BASE_URL}{{ step.target }}`, { waitUntil: 'load' });
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    {% elif step.accion == 'expand_collapsible' %}
    // [STEP {{ '%02d' | format(loop.index) }}] expand collapsible search panel
    console.log('[STEP {{ '%02d' | format(loop.index) }}] expand collapsible');
    await page.locator('.collapsible-header:has-text("Búsqueda Avanzada")').first().click();
    await page.waitForTimeout(800);
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    {% elif step.accion == 'click' %}
    // [STEP {{ '%02d' | format(loop.index) }}] click {{ step.target }}
    console.log('[STEP {{ '%02d' | format(loop.index) }}] click {{ step.target }}');
    await page.locator("{{ ui_map[step.target] }}").click({ force: true });
    await page.waitForLoadState('load');
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    {% elif step.accion == 'fill' %}
    // [STEP {{ '%02d' | format(loop.index) }}] fill {{ step.target }} with "{{ step.valor }}"
    console.log('[STEP {{ '%02d' | format(loop.index) }}] fill {{ step.target }}');
    await page.locator("{{ ui_map[step.target] }}").fill('{{ step.valor }}', { force: true });;
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    {% elif step.accion == 'select' %}
    // [STEP {{ '%02d' | format(loop.index) }}] select {{ step.valor }} in {{ step.target }}
    console.log('[STEP {{ '%02d' | format(loop.index) }}] select {{ step.target }}');
    await page.locator("{{ ui_map[step.target] }}").selectOption('{{ step.valor }}', { force: true });;
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    {% elif step.accion == 'select_by_index' %}
    // [STEP {{ '%02d' | format(loop.index) }}] select index {{ step.valor }} in {{ step.target }}
    console.log('[STEP {{ '%02d' | format(loop.index) }}] select_by_index {{ step.target }}');
    await page.evaluate((sel: string) => {
      const el = document.querySelector(sel) as HTMLSelectElement;
      if (el) { el.selectedIndex = {{ step.valor }}; el.dispatchEvent(new Event('change', { bubbles: true })); }
    }, "{{ ui_map[step.target] }}");
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    {% elif step.accion == 'wait_networkidle' %}
    // [STEP {{ '%02d' | format(loop.index) }}] wait load
    await page.waitForLoadState('load');
    {% elif step.accion == 'wait_visible' %}
    // [STEP {{ '%02d' | format(loop.index) }}] wait visible {{ step.target }}
    await expect(page.locator('{{ ui_map[step.target] }}')).toBeVisible({ timeout: 10000 });
    {% endif %}
    {% endfor %}

    // ASSERTIONS
    {% for oracle in oraculos %}
    {% if oracle.tipo == 'page_contains_text' %}
    await expect(page.locator('body'), '{{ scenario_id }}: página debe contener "{{ oracle.valor }}"').toContainText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'page_not_contains_text' %}
    await expect(page.locator('body'), '{{ scenario_id }}: página NO debe contener "{{ oracle.valor }}"').not.toContainText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'select_value_is' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe tener valor "{{ oracle.valor }}"').toHaveValue('{{ oracle.valor }}');
    {% elif oracle.tipo == 'equals' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe ser exactamente "{{ oracle.valor }}"').toHaveText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'contains_literal' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe contener "{{ oracle.valor }}"').toContainText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'contains_semantic' %}
    // SEMANTIC assertion — post-processed by uat_assertion_evaluator; using contains_literal as proxy
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe contener (semántico): "{{ oracle.valor }}"').toContainText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'count_gt' %}
    {
      const rowCount = await page.locator('{{ ui_map[oracle.target] }} tbody tr').count();
      await expect(rowCount, '{{ scenario_id }}: {{ oracle.target }} rows debe ser > {{ oracle.valor }}').toBeGreaterThan({{ oracle.valor | int }});
    }
    {% elif oracle.tipo == 'count_eq' %}
    {
      const rowCount = await page.locator('{{ ui_map[oracle.target] }} tbody tr').count();
      await expect(rowCount, '{{ scenario_id }}: {{ oracle.target }} rows debe ser == {{ oracle.valor }}').toBe({{ oracle.valor | int }});
    }
    {% elif oracle.tipo == 'visible' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe ser visible').toBeVisible();
    {% elif oracle.tipo == 'invisible' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} no debe ser visible').toBeHidden();
    {% elif oracle.tipo == 'state' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}')).toHaveAttribute('{{ oracle.valor }}', '');
    {% endif %}
    {% endfor %}

    // CLEANUP
    await page.context().clearCookies();
  });

  test.afterEach(async ({ page }) => {
    // Capture final state screenshot first — fail-safe even if the page is
    // mid-PostBack.
    try {
      await page.screenshot({
        path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_final_state.png',
      });
    } catch (_e) {
      // ignore — page may be closed or navigating
    }

    // ASSERTIONS EVIDENCE — capture actual values for every oracle so
    // uat_assertion_evaluator.py can reconcile expected vs actual without
    // relying on Playwright's pass/fail (which conflates product defects
    // with pipeline defects).
    const captured: any[] = [];
    for (const probe of ORACLE_PROBES) {
      const entry: any = {
        oracle_id: probe.oracle_id,
        target: probe.target,
        tipo: probe.tipo,
        expected: probe.expected,
      };
      try {
        if (probe.selector === null) {
          // Whole-page oracle: capture the body text once (truncated).
          const bodyText = (await page.locator('body').innerText({ timeout: 2000 })) || '';
          entry.actual_text = bodyText.slice(0, 4000);
          entry.visible = true;
        } else {
          const loc = page.locator(probe.selector);
          // count
          const count = await loc.count();
          entry.count = count;
          if (count === 0) {
            entry.visible = false;
            entry.actual_text = null;
          } else {
            entry.visible = await loc.first().isVisible({ timeout: 2000 });
            // value (form controls)
            try {
              entry.value = await loc.first().inputValue({ timeout: 1000 });
            } catch (_e) { /* not a form control */ }
            // textContent
            try {
              const txt = (await loc.first().innerText({ timeout: 1500 })) || '';
              entry.actual_text = txt.slice(0, 1000);
            } catch (_e) {
              entry.actual_text = null;
            }
            // disabled / state
            try {
              entry.state = (await loc.first().isDisabled({ timeout: 500 })) ? 'disabled' : 'enabled';
            } catch (_e) { /* ignore */ }
          }
        }
      } catch (e: any) {
        entry.capture_error = String(e && e.message ? e.message : e).slice(0, 300);
      }
      captured.push(entry);
    }

    // Persist assertions_<sid>.json. mkdir is safe-recursive; failures here
    // must not break the test runner.
    try {
      const outPath = path.resolve(process.cwd(), ASSERTIONS_OUT_PATH);
      fs.mkdirSync(path.dirname(outPath), { recursive: true });
      fs.writeFileSync(
        outPath,
        JSON.stringify(
          { scenario_id: '{{ scenario_id }}', assertions: captured },
          null, 2,
        ),
        'utf-8',
      );
    } catch (e) {
      console.error('[afterEach] could not persist assertions json:', e);
    }

    await page.context().clearCookies();
  });
});
