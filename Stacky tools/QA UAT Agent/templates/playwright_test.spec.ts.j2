    await page.locator("{{ ui_map[step.target] }}[value={{ step.valor | tojson }}]").check();
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    STEP_BBOXES.push({ step_index: {{ loop.index }}, screenshot_path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png', target: {{ step.target | tojson }}, bbox: await page.locator("{{ ui_map[step.target] }}[value={{ step.valor | tojson }}]").boundingBox().catch(() => null) });
    {% if detect_screen_errors %}await __checkScreenAfterStep(page, {{ loop.index }}, 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png');{% endif %}
    {% elif step.accion == 'clear' %}
    // [STEP {{ '%02d' | format(loop.index) }}] clear {{ step.target }}
    console.log('[STEP {{ '%02d' | format(loop.index) }}] clear {{ step.target }}');
    await page.locator("{{ ui_map[step.target] }}").scrollIntoViewIfNeeded().catch(() => null);
    await page.locator("{{ ui_map[step.target] }}").clear();
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    {% elif step.accion == 'wait_for_text' %}
    // [STEP {{ '%02d' | format(loop.index) }}] wait for text "{{ step.valor }}" in {{ step.target }}
    console.log('[STEP {{ '%02d' | format(loop.index) }}] wait_for_text {{ step.target }}');
    await expect(page.locator("{{ ui_map[step.target] }}")).toContainText({{ step.valor | tojson }}, { timeout: 15000 });
    {% elif step.accion == 'scroll_into_view' %}
    // [STEP {{ '%02d' | format(loop.index) }}] scroll_into_view {{ step.target }}
    console.log('[STEP {{ '%02d' | format(loop.index) }}] scroll_into_view {{ step.target }}');
    await page.locator("{{ ui_map[step.target] }}").scrollIntoViewIfNeeded();
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_{{ '%02d' | format(loop.index) }}_after.png' });
    {% endif %}
    {% endfor %}

    // ASSERTIONS
    {% for oracle in oraculos %}
    {% if oracle.tipo == 'page_contains_text' %}
    await expect(page.locator('body'), '{{ scenario_id }}: página debe contener "{{ oracle.valor }}"').toContainText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'page_not_contains_text' %}
    await expect(page.locator('body'), '{{ scenario_id }}: página NO debe contener "{{ oracle.valor }}"').not.toContainText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'select_value_is' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe tener valor "{{ oracle.valor }}"').toHaveValue('{{ oracle.valor }}');
    {% elif oracle.tipo == 'equals' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe ser exactamente "{{ oracle.valor }}"').toHaveText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'contains_literal' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe contener "{{ oracle.valor }}"').toContainText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'contains_semantic' %}
    // SEMANTIC assertion — post-processed by uat_assertion_evaluator; using contains_literal as proxy
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe contener (semántico): "{{ oracle.valor }}"').toContainText('{{ oracle.valor }}');
    {% elif oracle.tipo == 'count_gt' %}
    {
      const rowCount = await page.locator('{{ ui_map[oracle.target] }} tbody tr').count();
      await expect(rowCount, '{{ scenario_id }}: {{ oracle.target }} rows debe ser > {{ oracle.valor }}').toBeGreaterThan({{ oracle.valor | int }});
    }
    {% elif oracle.tipo == 'count_eq' %}
    {
      const rowCount = await page.locator('{{ ui_map[oracle.target] }} tbody tr').count();
      await expect(rowCount, '{{ scenario_id }}: {{ oracle.target }} rows debe ser == {{ oracle.valor }}').toBe({{ oracle.valor | int }});
    }
    {% elif oracle.tipo == 'visible' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} debe ser visible').toBeVisible();
    {% elif oracle.tipo == 'invisible' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}'), '{{ scenario_id }}: {{ oracle.target }} no debe ser visible').toBeHidden();
    {% elif oracle.tipo == 'state' %}
    await expect(page.locator('{{ ui_map[oracle.target] }}')).toHaveAttribute('{{ oracle.valor }}', '');
    {% elif oracle.tipo == 'field_ais_state' %}
    // AIS FieldState — multi-signal readonly/disabled detection.
    // No native Playwright assertion; evidence captured in afterEach (ais_state object).
    // uat_assertion_evaluator.py evaluates derived 'state' field against expected: '{{ oracle.valor }}'.
    console.log('[ORACLE {{ loop.index0 }}] field_ais_state {{ oracle.target }} expected={{ oracle.valor }}');
    {% endif %}
    {% endfor %}

    // Final screenshot after all assertions
    await page.screenshot({ path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_final_state.png' }).catch(() => null);
  });

  test.afterEach(async ({ page }) => {
    // afterEach runs AFTER the test body — including after failures.
    // The final screenshot was already taken in the test body; here we only
    // capture evidence if the test crashed before reaching it.
    try {
      await page.screenshot({
        path: 'evidence/{{ ticket_id }}/{{ scenario_id }}/step_aftereach_state.png',
      });
    } catch (_e) {
      // ignore — page may be closed or navigating
    }

    // ASSERTIONS EVIDENCE — capture actual values for every oracle so
    // uat_assertion_evaluator.py can reconcile expected vs actual without
    // relying on Playwright's pass/fail (which conflates product defects
    // with pipeline defects).
    const captured: any[] = [];
    for (const probe of ORACLE_PROBES) {
      const entry: any = {
        oracle_id: probe.oracle_id,
        target: probe.target,
        tipo: probe.tipo,
        expected: probe.expected,
      };
      try {
        if (probe.selector === null) {
          // Whole-page oracle: capture the body text once (truncated).
          const bodyText = (await page.locator('body').innerText({ timeout: 2000 })) || '';
          entry.actual_text = bodyText.slice(0, 4000);
          entry.visible = true;
        } else if (probe.tipo === 'field_ais_state') {
          // Fase 4: AIS FieldState multi-signal detection.
          // Captures all signals AIS WebForms uses to express ReadOnly/Disabled:
          //   fieldstate attr, disabled, readOnly, aspNetDisabled class,
          //   CSS pointer-events:none, aria-readonly.
          const aisState = await page.evaluate((sel: string) => {
            const el = document.querySelector(sel) as HTMLElement | null;
            if (!el) return null;
            const inp = el as HTMLInputElement;
            const cs = window.getComputedStyle(el);
            return {
              fieldstate: el.getAttribute('fieldstate') || null,
              disabled: inp.disabled === true,
              readonly: inp.readOnly === true,
              has_readonly: el.hasAttribute('readonly'),
              aspnet_disabled: el.classList.contains('aspNetDisabled'),
              css_no_pointer: cs.pointerEvents === 'none',
              aria_readonly: el.getAttribute('aria-readonly') === 'true',
            };
          }, probe.selector).catch(() => null);
          entry.ais_state = aisState;
          if (aisState) {
            const isReadonly = aisState.fieldstate?.toUpperCase() === 'READONLY'
              || aisState.readonly || aisState.has_readonly
              || aisState.css_no_pointer || aisState.aria_readonly;
            const isDisabled = aisState.disabled || aisState.aspnet_disabled;
            entry.state = isReadonly ? 'readonly' : isDisabled ? 'disabled' : 'enabled';
            entry.visible = await page.locator(probe.selector).first().isVisible({ timeout: 2000 }).catch(() => null);
          } else {
            entry.state = null;
            entry.visible = false;
          }
        } else {
          const loc = page.locator(probe.selector);
          // count
          const count = await loc.count();
          entry.count = count;
          if (count === 0) {
            entry.visible = false;
            entry.actual_text = null;
          } else {
            entry.visible = await loc.first().isVisible({ timeout: 2000 });
            // value (form controls)
            try {
              entry.value = await loc.first().inputValue({ timeout: 1000 });
            } catch (_e) { /* not a form control */ }
            // textContent
            try {
              const txt = (await loc.first().innerText({ timeout: 1500 })) || '';
              entry.actual_text = txt.slice(0, 1000);
            } catch (_e) {
              entry.actual_text = null;
            }
            // disabled / state
            try {
              entry.state = (await loc.first().isDisabled({ timeout: 500 })) ? 'disabled' : 'enabled';
            } catch (_e) { /* ignore */ }
          }
        }
      } catch (e: any) {
        entry.capture_error = String(e && e.message ? e.message : e).slice(0, 300);
      }
      captured.push(entry);
    }

    // Persist assertions_<sid>.json. mkdir is safe-recursive; failures here
    // must not break the test runner.
    try {
      const outPath = path.resolve(process.cwd(), ASSERTIONS_OUT_PATH);
      fs.mkdirSync(path.dirname(outPath), { recursive: true });
      fs.writeFileSync(
        outPath,
        JSON.stringify(
          { scenario_id: '{{ scenario_id }}', assertions: captured },
          null, 2,
        ),
        'utf-8',
      );
    } catch (e) {
      console.error('[afterEach] could not persist assertions json:', e);
    }

    // Persist step_bboxes.json for screenshot_annotator.py (Fase 2).
    // Non-fatal: if this fails the pipeline continues without annotations.
    if (STEP_BBOXES.length > 0) {
      try {
        const bboxOutPath = path.resolve(process.cwd(), STEP_BBOXES_OUT_PATH);
        fs.mkdirSync(path.dirname(bboxOutPath), { recursive: true });
        fs.writeFileSync(bboxOutPath, JSON.stringify(STEP_BBOXES, null, 2), 'utf-8');
      } catch (e) {
        console.error('[afterEach] could not persist step_bboxes json:', e);
      }
    }
{% if detect_screen_errors %}
    // Persist screen_errors_<sid>.json regardless of pass/fail. Even when
    // the test passes, the file documents that we checked and found
    // nothing — useful when debugging false positives later.
    try {
      const seOutPath = path.resolve(process.cwd(), SCREEN_ERRORS_OUT_PATH);
      fs.mkdirSync(path.dirname(seOutPath), { recursive: true });
      fs.writeFileSync(
        seOutPath,
        JSON.stringify(
          { scenario_id: '{{ scenario_id }}', detector_version: '1.0.0', entries: SCREEN_ERRORS },
          null, 2,
        ),
        'utf-8',
      );
    } catch (e) {
      console.error('[afterEach] could not persist screen_errors json:', e);
    }
{% endif %}
  });
});
