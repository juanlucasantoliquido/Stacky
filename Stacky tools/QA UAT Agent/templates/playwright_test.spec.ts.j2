// SCREEN_ERRORS — Fase 4 enhancement.
// Después de cada acción (fill/click/select/...) escaneamos el DOM por
// patrones conocidos de error de la Agenda Web (validators ASP.NET,
// alertas Bootstrap, mensajes "campo requerido", etc.). Si detectamos
// un error VISIBLE, fallamos el step inmediatamente con el texto del
// error en el mensaje — antes era el agente quien tenía que adivinar
// por qué Playwright se atascaba.
//
// Opcionalmente, si QA_UAT_VISION_DETECTOR_URL está seteada, también
// mandamos el screenshot al detector LLM-vision para casos donde el
// error no esté en el DOM (ej. modales pintados con canvas / iframes
// cross-origin / mensajes embebidos en imágenes).
type ScreenErrorEntry = {
  step_index: number;
  screenshot_path: string | null;
  source: 'dom' | 'vision' | 'runtime';
  errors: { text: string; source: string }[];
  category?: string;
  confidence?: string;
  captured_at: string;
};
const SCREEN_ERRORS: ScreenErrorEntry[] = [];
const SCREEN_ERRORS_OUT_PATH = 'evidence/{{ ticket_id }}/{{ scenario_id }}/screen_errors_{{ scenario_id }}.json';
const VISION_DETECTOR_URL = process.env.QA_UAT_VISION_DETECTOR_URL || '';
const FAIL_ON_SCREEN_ERROR = process.env.QA_UAT_FAIL_ON_SCREEN_ERROR !== '0';

{{ screen_error_detector_js }}

async function __checkScreenAfterStep(
  page: any, stepIndex: number, screenshotPath: string,
): Promise<void> {
  let domErrors: { text: string; source: string }[] = [];
  try {
    const r = await __detectScreenErrors(page);
    domErrors = (r && r.errors) || [];
  } catch (e: any) {
    // Never let the detector itself break the test. We log + continue.
    console.warn('[screen_errors] detector failed at step ' + stepIndex + ': ' + (e && e.message ? e.message : e));
  }
  if (domErrors.length > 0) {
    const entry: ScreenErrorEntry = {
      step_index: stepIndex,
      screenshot_path: screenshotPath,
      source: 'dom',
      errors: domErrors,
      captured_at: new Date().toISOString(),
    };
    SCREEN_ERRORS.push(entry);
    const summary = domErrors.map(e => e.text).join(' | ').slice(0, 280);
    console.log('[screen_errors] step ' + stepIndex + ' DOM error: ' + summary);
    if (FAIL_ON_SCREEN_ERROR) {
      throw new Error('Error de UI detectado tras step ' + stepIndex + ': ' + summary);
    }
  }
{% if detect_screen_errors_vision %}
  if (VISION_DETECTOR_URL) {
    try {
      const buf = fs.readFileSync(screenshotPath);
      const b64 = buf.toString('base64');
      const resp = await fetch(VISION_DETECTOR_URL.replace(/\/$/, '') + '/analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          image_base64: b64,
          scenario_id: '{{ scenario_id }}',
          step_index: stepIndex,
          screenshot_path: screenshotPath,
        }),
      });
      const verdict = await resp.json().catch(() => ({}));
      if (verdict && verdict.has_error) {
        const txt = String(verdict.error_text || '').slice(0, 280);
        SCREEN_ERRORS.push({
          step_index: stepIndex,
          screenshot_path: screenshotPath,
          source: 'vision',
          errors: [{ text: txt, source: 'vision' }],
          category: verdict.category,
          confidence: verdict.confidence,
          captured_at: new Date().toISOString(),
        });
        console.log('[screen_errors] step ' + stepIndex + ' VISION error: ' + txt);
        if (FAIL_ON_SCREEN_ERROR) {
          throw new Error('Error de UI (visión) tras step ' + stepIndex + ': ' + txt);
        }
      }
    } catch (e: any) {
      // Vision detector is best-effort. Network/parse errors are logged but
      // never fail the test — DOM detection is the authoritative path.
      const msg = (e && e.message) ? e.message : String(e);
      if (msg.startsWith('Error de UI')) throw e;  // re-throw real failures
      console.warn('[screen_errors] vision call failed at step ' + stepIndex + ': ' + msg);
    }
  }
{% endif %}
}
