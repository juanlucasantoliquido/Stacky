{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kaizen/v1/change_set.schema.json",
  "title": "Kaizen Change Set",
  "description": "Cambios declarativos que produce el improver (engine) y aplica apply.py de forma determinista y reversible. El modelo NUNCA toca el filesystem: sólo describe qué escribir. Toda ruta debe quedar dentro de kaizen/ y respetar el guardarraíl (ver scripts/aotl_state.py).",
  "type": "object",
  "additionalProperties": false,
  "required": ["changes"],
  "properties": {
    "session_id": { "type": "string" },
    "note": { "type": "string", "description": "Nota libre opcional." },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string", "description": "Ruta relativa a kaizen/." },
          "action": { "type": "string", "enum": ["create", "modify", "delete"] },
          "content": { "type": "string", "description": "Contenido COMPLETO resultante (obligatorio en create/modify)." }
        }
      }
    }
  }
}
