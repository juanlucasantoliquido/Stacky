#!/bin/bash
# post-commit hook — X-01: CI/CD Stacky + SVN
#
# Instalacion: copiar este archivo a <repo>/hooks/post-commit
# y dar permisos de ejecucion: chmod +x hooks/post-commit
#
# Variables disponibles del servidor SVN:
#   $1 = REPOS   (ruta del repositorio)
#   $2 = REV     (numero de revision)

REPOS="$1"
REV="$2"

# URL del dashboard Stacky
STACKY_URL="${STACKY_URL:-http://localhost:5050}"
PROJECT="${STACKY_PROJECT:-RIPLEY}"

# Obtener info del commit
AUTHOR=$(svnlook author -r "$REV" "$REPOS" 2>/dev/null)
LOG=$(svnlook log -r "$REV" "$REPOS" 2>/dev/null)
CHANGED=$(svnlook changed -r "$REV" "$REPOS" 2>/dev/null | awk '{print $2}' | tr '\n' ',' | sed 's/,$//')

# Construir JSON payload
PAYLOAD=$(cat <<EOF
{
  "revision": "$REV",
  "author": "$AUTHOR",
  "message": $(echo "$LOG" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read().strip()))"),
  "files": $(echo "$CHANGED" | python3 -c "import sys,json; parts=[p.strip() for p in sys.stdin.read().split(',') if p.strip()]; print(json.dumps(parts))"),
  "project": "$PROJECT"
}
EOF
)

# Notificar a Stacky (no bloqueante — hook no debe demorar el commit)
curl -s -o /dev/null -w "%{http_code}" \
     -X POST \
     -H "Content-Type: application/json" \
     -d "$PAYLOAD" \
     "${STACKY_URL}/api/v1/hooks/post-commit" \
     --connect-timeout 3 \
     --max-time 5 \
     2>/dev/null || true

exit 0
